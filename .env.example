# BizChat — variables de entorno
# Copia este archivo a .env.local y agrega AL MENOS una API key.
# El proveedor por defecto es Anthropic (Claude), así que basta con ANTHROPIC_API_KEY.

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google (Gemini) — https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Modelo de IA que usará el chatbot. Lo elige el dueño AQUÍ (backend), no el
# visitante. Debe coincidir con la API key configurada arriba.
# Opciones: openai | anthropic | google
DEFAULT_PROVIDER=anthropic

# Dominios permitidos para llamar a /api/chat, separados por comas.
# Sin esta variable el endpoint acepta cualquier origen (y la API key queda
# expuesta al abuso de costos). Ej: https://bizchat.pipelol.dev,https://cliente.com
ALLOWED_ORIGINS=

# Rate-limit persistente (Upstash Redis). En Vercel se inyectan solas al conectar
# la base; solo hace falta ponerlas aquí para probar el límite compartido en local.
# Sin ellas, el rate-limit cae a un contador en memoria por instancia.
KV_REST_API_URL=
KV_REST_API_TOKEN=
